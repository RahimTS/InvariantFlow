STORAGE_BACKEND=local
SQLITE_DB_PATH=invariantflow.db

# Docker mode (when STORAGE_BACKEND=docker)
POSTGRES_DSN=postgresql://invariantflow:invariantflow@localhost:5432/invariantflow
REDIS_URL=redis://localhost:6379/0
REDIS_STATE_TTL_SECONDS=3600
REDIS_EVENTS_CHANNEL=events:testing

# LLM / OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Frontend
FRONTEND_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:8000
